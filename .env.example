# ============================================================================
# Agentwerke — Environment Variables Template
# Copy this file to `.env.local` and fill in real values.
# Never commit `.env.local` to git.
# ============================================================================

# --- Anthropic ---
# Get from https://console.anthropic.com/settings/keys
# Use a workspace-scoped key for this project so spend is tracked separately.
ANTHROPIC_API_KEY=sk-ant-...

# Optional: override the default model. Defaults to Haiku 4.5 if unset.
# Options: claude-haiku-4-5 | claude-sonnet-4-6 | claude-opus-4-7
# ANTHROPIC_MODEL=claude-haiku-4-5

# --- Cal.com (booking) ---
# Get from https://cal.com/settings/developer/api-keys
# We use Cal.com v2 API. The event type slug is the URL slug for your
# discovery call event (e.g., "discovery-call" → cal.com/yourname/discovery-call)
# To find CALCOM_EVENT_TYPE_ID, run:
#   curl -H "Authorization: Bearer $CALCOM_API_KEY" -H "cal-api-version: 2024-08-13" https://api.cal.com/v2/event-types
CALCOM_API_KEY=cal_live_...
CALCOM_USERNAME=jason
CALCOM_EVENT_TYPE_SLUG=discovery-call
CALCOM_EVENT_TYPE_ID=

# --- Resend (transactional email) ---
# Get from https://resend.com/api-keys
# FROM_EMAIL must be on a domain you've verified in Resend.
# For local testing before DNS is set up, use: onboarding@resend.dev
# (note: that only delivers to the email you signed up with)
RESEND_API_KEY=re_...
FROM_EMAIL=avery@agentwerke.com
FOUNDER_EMAIL=jason@agentwerke.com

# --- Supabase (conversation persistence) ---
# Get from https://supabase.com/dashboard/project/_/settings/api
# Service role key is server-side only — NEVER expose to client.
SUPABASE_URL=https://xxx.supabase.co
SUPABASE_SERVICE_ROLE_KEY=eyJ...
NEXT_PUBLIC_SUPABASE_URL=https://xxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...

# --- App Config ---
# Used in confirmation emails and agent self-reference.
NEXT_PUBLIC_APP_URL=https://agentwerke.com
NEXT_PUBLIC_AGENCY_NAME=Agentwerke
NEXT_PUBLIC_AGENT_NAME=Avery

# --- Optional: Observability (uncomment when adding) ---
# LANGFUSE_PUBLIC_KEY=
# LANGFUSE_SECRET_KEY=
# LANGFUSE_HOST=https://cloud.langfuse.com
